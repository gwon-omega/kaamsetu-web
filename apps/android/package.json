{
  "name": "@shram-sewa/android",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "dev:clear": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "config:public": "expo config --type public",
    "prebuild:android": "expo prebuild --platform android --no-install",
    "eas:build:preview": "npx eas-cli build --platform android --profile preview",
    "eas:build:production": "npx eas-cli build --platform android --profile production",
    "eas:submit:production": "npx eas-cli submit --platform android --profile production",
    "build": "expo export",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@nozbe/watermelondb": "^0.28.0",
    "@shram-sewa/shared": "workspace:*",
    "@shram-sewa/ui-tokens": "workspace:*",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.56.0",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.2",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.19",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.1",
    "lottie-react-native": "6.7.0",
    "lucide-react-native": "^1.7.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-mmkv": "^2.12.2",
    "react-native-paper": "^5.12.5",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-svg": "^15.2.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "babel-preset-expo": "~11.0.0",
    "typescript": "^5.3.3"
  }
}
